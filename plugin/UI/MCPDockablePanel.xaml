<Page x:Class="revit_mcp_plugin.UI.MCPDockablePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Background="#1E1E2E" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#353550" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Claude" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" + Revit" Foreground="#8080A0" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="#FF4444" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StatusText" Text="MCP Off" Foreground="#FF6666" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <Border Grid.Row="1" Background="#2A2A3C">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabChat" Content="Chat" Click="TabChat_Click"
                        Background="#5B5BD6" Foreground="White" BorderThickness="0"
                        Padding="20,6" FontSize="12" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="0"/></Style></Button.Resources>
                </Button>
                <Button x:Name="TabCommands" Content="Comandi Rapidi" Click="TabCommands_Click"
                        Background="#2A2A3C" Foreground="#9090A8" BorderThickness="0"
                        Padding="20,6" FontSize="12" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="0"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="2">

            <!-- TAB 1: Chat (WebView2) -->
            <Grid x:Name="ChatPanel" Visibility="Visible">
                <wv2:WebView2 x:Name="WebBrowser" DefaultBackgroundColor="#1E1E2E"/>
                <Border x:Name="LoadingOverlay" Background="#1E1E2E" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Caricamento Claude..." Foreground="#8080A0" FontSize="15" HorizontalAlignment="Center"/>
                        <TextBlock Text="Accedi con il tuo account Teams" Foreground="#606080" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- TAB 2: Quick Commands -->
            <ScrollViewer x:Name="CommandsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">

                    <!-- Info Section -->
                    <TextBlock Text="INFORMAZIONI" Foreground="#6060A0" FontSize="10" FontWeight="Bold" Margin="4,8,0,6"/>
                    <WrapPanel>
                        <Button Content="Info Progetto" Tag="get_project_info" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Statistiche Modello" Tag="analyze_model_statistics" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Warnings" Tag="get_warnings" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Materiali" Tag="get_materials" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Dati Stanze" Tag="export_room_data" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Quantita Materiali" Tag="get_material_quantities" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3A4C" Foreground="#88BBEE" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                    </WrapPanel>

                    <!-- Create Section -->
                    <TextBlock Text="CREA" Foreground="#60A060" FontSize="10" FontWeight="Bold" Margin="4,16,0,6"/>
                    <WrapPanel>
                        <Button Content="Nuovo Livello" Tag="create_level_dialog" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Vista 3D" Tag="create_3d" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Sezione" Tag="create_section" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Nuovo Sheet" Tag="create_sheet_dialog" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Schedule Colonne" Tag="create_schedule_columns" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Schedule Travi" Tag="create_schedule_beams" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#2A3C2A" Foreground="#88EE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                    </WrapPanel>

                    <!-- Cleanup Section -->
                    <TextBlock Text="MANUTENZIONE" Foreground="#A06060" FontSize="10" FontWeight="Bold" Margin="4,16,0,6"/>
                    <WrapPanel>
                        <Button Content="Purge (Preview)" Tag="purge_preview" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#3C2A2A" Foreground="#EE8888" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                        <Button Content="Purge (Esegui)" Tag="purge_execute" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#3C2A2A" Foreground="#EE8888" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                    </WrapPanel>

                    <!-- Test Section -->
                    <TextBlock Text="TEST" Foreground="#A0A060" FontSize="10" FontWeight="Bold" Margin="4,16,0,6"/>
                    <WrapPanel>
                        <Button Content="Say Hello!" Tag="say_hello" Click="QuickCmd_Click" Style="{x:Null}"
                                Background="#3C3C2A" Foreground="#EEEE88" BorderThickness="0" Padding="12,8" Margin="4" FontSize="11" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                        </Button>
                    </WrapPanel>

                    <!-- Result Display -->
                    <TextBlock Text="RISULTATO" Foreground="#6060A0" FontSize="10" FontWeight="Bold" Margin="4,16,0,6"/>
                    <Border Background="#2A2A3C" CornerRadius="8" Padding="10" Margin="4">
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ResultText" Text="Clicca un comando per eseguirlo..."
                                       Foreground="#C0C0D8" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
