<Page x:Class="revit_mcp_plugin.UI.MCPDockablePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#2B2B2B" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar - Claude style minimal -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Claude logo circle -->
                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                        Background="#D97757" Margin="0,0,10,0">
                    <TextBlock Text="C" Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Claude for Revit" Foreground="#ECECEC" FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusIndicator" Width="6" Height="6" Fill="#FF4444" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="MCP Offline" Foreground="#888" FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="Nuova chat" Foreground="#888" FontSize="11"
                           Cursor="Hand" MouseLeftButtonDown="ClearChat_Click"
                           VerticalAlignment="Center" Margin="0,0,6,0">
                    <TextBlock.TextDecorations>
                        <TextDecorationCollection/>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                      Background="#2B2B2B" Padding="0">
            <ItemsControl x:Name="ChatMessages">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}" Padding="16,12">
                            <Grid MaxWidth="680" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                        Background="{Binding AvatarBackground}" Margin="0,2,12,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Message content -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding RoleLabel}" Foreground="{Binding RoleLabelColor}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Text}" Foreground="{Binding TextColor}"
                                               FontSize="13" TextWrapping="Wrap" FontFamily="{Binding FontFamily}"
                                               LineHeight="20"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Typing indicator -->
        <Border Grid.Row="2" x:Name="TypingIndicator" Visibility="Collapsed"
                Background="#303030" Padding="16,8">
            <Grid MaxWidth="680">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                        Background="#D97757" Margin="0,0,12,0">
                    <TextBlock Text="C" Foreground="White" FontSize="11" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TypingText" Text="Claude sta pensando..."
                           Foreground="#999" FontSize="13" FontStyle="Italic" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Input Area - Claude style -->
        <Border Grid.Row="3" Background="#1A1A1A" Padding="16,12">
            <Border Background="#3A3A3A" CornerRadius="12" Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Grid.Column="0"
                             Background="Transparent" Foreground="#E8E8E8" CaretBrush="#E8E8E8"
                             BorderThickness="0" Padding="12,10" FontSize="13"
                             AcceptsReturn="False" KeyDown="ChatInput_KeyDown"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="SendButton" Grid.Column="1" Click="Send_Click"
                            Background="Transparent" BorderThickness="0"
                            Padding="10,8" Margin="0,0,4,0" Cursor="Hand">
                        <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Fill="#D97757"
                              Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
